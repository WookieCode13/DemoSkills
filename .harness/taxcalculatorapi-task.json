{
    "family": "taxcalculatorapi-task",
    "containerDefinitions": [
        {
            "cpu": 0,
            "environment": [
                {
                    "name": "BUILD_REF",
                    "value": "main"
                },
                {
                    "name": "BUILD_BRANCH",
                    "value": "main"
                }
            ],
            "environmentFiles": [],
            "essential": true,
            "image": "356171277691.dkr.ecr.us-east-1.amazonaws.com/demoskills:TaxCalculatorAPI-main.b29",
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/taxcalculatorapi-task",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "mountPoints": [],
            "name": "taxcalculatorapi",
            "portMappings": [
                {
                    "appProtocol": "http",
                    "containerPort": 8083,
                    "hostPort": 8083,
                    "name": "taxcalculatorapi-8083-tcp",
                    "protocol": "tcp"
                }
            ],
            "systemControls": [],
            "ulimits": [],
            "volumesFrom": []
        }
    ],
    "taskRoleArn": "arn:aws:iam::356171277691:role/demoskillsapi-task-role",
    "executionRoleArn": "arn:aws:iam::356171277691:role/demoskillsapi-ecs-execution",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "enableFaultInjection": false
}
